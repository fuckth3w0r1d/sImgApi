PORT=3000

# 数据存储目录
DATA_DIR=./data

# 代理图片缓存目录
CACHE_DIR=./cache

# 种子图库配置文件路径（JSON格式），默认 ./config/seed.json
# 参考 config/seed.example.json
SEED_CONFIG=./config/seed.json

# 备用：直接在env配置（格式：tag|url1,url2;tag2|url3）
# SEED_GALLERIES=

# 并发下载数（seed 和 search-crawl），默认 5
SEED_CONCURRENCY=5

# 单次 fetch 超时（毫秒），默认 15000
FETCH_TIMEOUT_MS=15000
